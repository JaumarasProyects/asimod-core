{
    "type": "Prop",
    "description": "Receta para la creación y evolución de un objeto (Prop).",
    "grades": {
        "1": {
            "panel": "Texto",
            "instruction": "Define el título, descripción y utilidad del objeto."
        },
        "2": {
            "panel": "Imagen",
            "workflow_folder": "workflows/imagen/compuesta/prop/imagen",
            "default_workflow": "prop_render.json",
            "prompt_template": "Diseño conceptual de {titulo}: {descripcion}. Utilidad: {utilidad}.",
            "narrative_enrichment": false,
            "audio_planning": true
        },
        "3": {
            "panel": "Audio",
            "workflow_folder": "workflows/Audio/sounds",
            "default_workflow": "prop_sound_fx.json"
        },
        "4": {
            "panel": "Video",
            "workflow_folder": "workflows/video/simple/Img+Audio2Video",
            "default_workflow": "DefaultImg+Audio2Video.json"
        }
    }
}
